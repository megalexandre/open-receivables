{
  "priority": 5,
  "request": { "method": "PUT", "urlPathPattern": "/addresses/[0-9]+" },
  "response": {
    "status": 200,
    "headers": { "Content-Type": "application/json" },
    "body": "{\"id\": {{request.pathSegments.[1]}}, \"address_type\": \"{{jsonPath request.body '$.address_type'}}\", \"name\": \"{{jsonPath request.body '$.name'}}\", \"notes\": null}"
  }
}
